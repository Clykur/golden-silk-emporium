# ============================================================
# GOLDEN SILK EMPORIUM — NEXT.JS ENVIRONMENT VARIABLES
# Copy this file to .env.local for local development.
# All secrets must be added to Vercel / GitHub Secrets for CI/CD.
# ============================================================

# --- PUBLIC CLIENT VARIABLES (exposed to browser, prefix NEXT_PUBLIC_) ---

# Supabase — required for all database & auth operations
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Razorpay — public key displayed in the checkout UI
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_razorpay_key_id"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Feature flags
# Set to "true" to activate maintenance mode (shows /maintenance page)
NEXT_PUBLIC_MAINTENANCE_MODE="false"

# Backend API URL (used by Next.js server-side rewrites to proxy API requests to Express)
BACKEND_API_URL="http://localhost:5001"

# --- SERVER-ONLY SECRETS (never exposed to the browser) ---

# Supabase service role key — used for admin/webhook operations only
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Razorpay secret key — used for order creation & signature verification
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# Razorpay webhook signing secret — set in the Razorpay dashboard
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# ZeptoMail transactional email configuration
ZEPTOMAIL_API_KEY="your_zeptomail_api_key"
ZEPTOMAIL_FROM_EMAIL="onboarding@yourdomain.com"
ZEPTOMAIL_FROM_NAME="Drapeva"

# WhatsApp Cloud API configuration
WHATSAPP_API_TOKEN="your_whatsapp_cloud_api_token"
WHATSAPP_PHONE_NUMBER_ID="your_whatsapp_phone_number_id"

# Webhook authentication secret — set in Supabase Webhook settings
ORDER_WEBHOOK_SECRET="some-very-long-random-string-for-webhook-security"
