{
  "name": "golden-silk-emporium",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "build": "npm run build -w frontend && npm run build -w backend",
    "start": "npm run start -w frontend",
    "lint": "npm run lint -w frontend",
    "lint:fix": "npm run lint:fix -w frontend",
    "typecheck": "npm run typecheck -w frontend",
    "format": "prettier --write \"frontend/**/*.{ts,tsx,js,jsx,json,css}\" \"backend/**/*.{ts,js,json}\" \"*.{ts,js,json}\"",
    "format:check": "npm run format:check -w frontend",
    "clean": "npm run clean -w frontend && rm -rf node_modules",
    "seed:supabase": "node frontend/scripts/seed-supabase.cjs",
    "db:seed": "npm run db:seed -w backend"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "eslint-config-next": "^16.2.9"
  }
}
